# Application Core
AP_CORE_ADAPTER=peppol
AP_CORE_DB_PATH=/data/ap-core.db
AP_CORE_WORKERS=8
AP_CORE_DRY_RUN=false
AP_CORE_TRUSTSTORE_PATH=/etc/ap-core/truststore.p12

# N42 Home
N42_HOME=/opt/n42

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-here
WEBHOOK_URL=https://your-webhook-endpoint.com/hook

# Server
PORT=3001
HOST=0.0.0.0
